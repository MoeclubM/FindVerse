FINDVERSE_CONTROL_API_PORT=8080
FINDVERSE_QUERY_API_PORT=8081
FINDVERSE_WEB_PORT=3000
FINDVERSE_POSTGRES_PORT=5432
FINDVERSE_REDIS_PORT=6379
FINDVERSE_OPENSEARCH_PORT=9200

FINDVERSE_CONTROL_API_BIND=0.0.0.0:8080
FINDVERSE_QUERY_API_BIND=0.0.0.0:8081
FINDVERSE_FRONTEND_ORIGIN=http://localhost:3000

FINDVERSE_LOCAL_ADMIN_USERNAME=admin
FINDVERSE_LOCAL_ADMIN_PASSWORD=change-me
FINDVERSE_BOOTSTRAP_ADMIN_ENABLED=true

FINDVERSE_POSTGRES_URL=postgres://findverse:findverse@postgres:5432/findverse
FINDVERSE_REDIS_URL=redis://valkey:6379/0
FINDVERSE_OPENSEARCH_URL=http://opensearch:9200
FINDVERSE_OPENSEARCH_INDEX=findverse-documents

FINDVERSE_INDEX_PATH=services/api/fixtures/bootstrap_documents.json
FINDVERSE_DEVELOPER_STORE=services/api/fixtures/developer_store.json
FINDVERSE_DEV_AUTH_STORE=services/api/fixtures/dev_auth_store.json

FINDVERSE_CRAWLER_MAINTENANCE_INTERVAL_SECS=15
FINDVERSE_CRAWLER_CLAIM_TIMEOUT_SECS=300
FINDVERSE_CRAWLER_JOIN_KEY=replace-with-join-key

FINDVERSE_CRAWLER_SERVER=http://control-api:8080
FINDVERSE_CRAWLER_MAX_JOBS=10
FINDVERSE_CRAWLER_POLL_INTERVAL_SECS=5
FINDVERSE_CRAWLER_CONCURRENCY=4
FINDVERSE_CRAWLER_ALLOWED_DOMAINS=
FINDVERSE_CRAWLER_PROXY=
