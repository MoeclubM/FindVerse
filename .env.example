# Shared env template for local and online deployment
# Copy this file to .env. Docker Compose reads it automatically.
# Persistent service data lives under ./data.

# Bindings
FINDVERSE_WEB_BIND_HOST=0.0.0.0
FINDVERSE_WEB_PORT=3000
FINDVERSE_INTERNAL_BIND_HOST=127.0.0.1
FINDVERSE_CONTROL_API_PORT=8080
FINDVERSE_QUERY_API_PORT=8081
FINDVERSE_POSTGRES_PORT=5432
FINDVERSE_REDIS_PORT=6379
FINDVERSE_OPENSEARCH_PORT=9200

# Public app origin
FINDVERSE_FRONTEND_ORIGIN=https://search.example.com

# Admin bootstrap
FINDVERSE_LOCAL_ADMIN_USERNAME=admin
FINDVERSE_LOCAL_ADMIN_PASSWORD=replace-with-a-long-random-password
# Set this to false after the first successful production login.
FINDVERSE_BOOTSTRAP_ADMIN_ENABLED=true

# Control plane / crawler scheduling
FINDVERSE_CRAWLER_MAINTENANCE_INTERVAL_SECS=15
FINDVERSE_CRAWLER_CLAIM_TIMEOUT_SECS=300
# Crawler nodes are expected to run with JS rendering enabled by default.
# Leave LLM filter settings unset for now and focus on crawl coverage / data acquisition first.

# Databases
FINDVERSE_POSTGRES_DB=findverse
FINDVERSE_POSTGRES_USER=findverse
FINDVERSE_POSTGRES_PASSWORD=replace-with-a-long-random-password
FINDVERSE_POSTGRES_URL=postgres://findverse:replace-with-a-long-random-password@postgres:5432/findverse
FINDVERSE_POSTGRES_MAX_CONNECTIONS=20
FINDVERSE_POSTGRES_ACQUIRE_TIMEOUT_SECS=5
FINDVERSE_REDIS_URL=redis://valkey:6379/0
FINDVERSE_OPENSEARCH_URL=http://opensearch:9200
FINDVERSE_OPENSEARCH_INDEX=findverse-documents

# Production-safe empty seed/import files mounted by docker-compose.yml
FINDVERSE_INDEX_PATH=/opt/findverse/production/empty-bootstrap-documents.json
FINDVERSE_DEVELOPER_STORE=/opt/findverse/production/empty-developer-store.json
FINDVERSE_DEV_AUTH_STORE=/opt/findverse/production/empty-dev-auth-store.json

# Memory tuning
FINDVERSE_POSTGRES_MEM_LIMIT=1g
FINDVERSE_VALKEY_MEM_LIMIT=256m
FINDVERSE_OPENSEARCH_JAVA_OPTS=-Xms1g -Xmx1g
FINDVERSE_OPENSEARCH_MEM_LIMIT=2g
FINDVERSE_CONTROL_API_MEM_LIMIT=512m
FINDVERSE_QUERY_API_MEM_LIMIT=512m
FINDVERSE_WEB_MEM_LIMIT=256m
