{
  "name": "findverse",
  "private": true,
  "version": "0.0.9",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present && cargo build --workspace",
    "build:web": "npm --workspace @findverse/web run build",
    "dev:web": "npm --workspace @findverse/web run dev",
    "lint:web": "npm --workspace @findverse/web run typecheck",
    "typecheck:web": "npm --workspace @findverse/web run typecheck",
    "test:e2e": "playwright test",
    "test": "npm run test --workspaces --if-present && cargo test --workspace",
    "format": "npm run format --workspaces --if-present"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
